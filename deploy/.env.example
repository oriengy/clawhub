# SkillHub 国内部署环境变量
# 复制为 .env 并填入实际值

# --- PostgreSQL (RDS) ---
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432

# --- Convex 实例配置 ---
# 启动后通过 docker compose exec backend ./generate_admin_key.sh 生成
INSTANCE_SECRET=

# --- 域名配置 ---
CONVEX_CLOUD_ORIGIN=http://api.skillhub.ver0.cn
CONVEX_SITE_ORIGIN=http://site.skillhub.ver0.cn
